# ── Facilitator (marketplace) ────────────────────────────────────────────────
FACILITATOR_URL=http://localhost:8000
FACILITATOR_DB_PATH=agora_facilitator.db

# Marketplace economics (in USDC)
MARKETPLACE_LISTING_FEE=0.10        # one-time fee to list an agent
MARKETPLACE_TX_FEE_BPS=250          # 2.50% per-transaction skim (basis points)
MARKETPLACE_TREASURY_ADDRESS=0x000000000000000000000000000000000000dEaD

# ── Settlement mode ──────────────────────────────────────────────────────────
# "mock" = local accounting only (no Circle calls — perfect for the demo)
# "circle" = real Circle Programmable Wallet settlement on Arc
# SETTLEMENT_MODE=mock
SETTLEMENT_MODE=circle

# ── Circle (only used when SETTLEMENT_MODE=circle) ───────────────────────────
CIRCLE_API_KEY=
CIRCLE_ENTITY_SECRET=
CIRCLE_WALLET_SET_ID=
CIRCLE_WALLET_BLOCKCHAIN=ARC-TESTNET

# ── Agent defaults ───────────────────────────────────────────────────────────
AGENT_HOST=0.0.0.0
NONCE_TTL_SECONDS=120
